# ====================================
# 環境變數配置模板
# ====================================
# 複製此文件為 .env.local 並填入實際值

# -------- 數據庫配置 --------
DATABASE_URL=postgresql://user:password@localhost:5432/news_sowork

# -------- AI API 配置 --------
# OpenAI API Key (用於新聞分析和 AI 論點生成)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Perplexity API Key (用於補充搜尋)
PERPLEXITY_API_KEY=xxxxxxxxxxxx

# -------- 認證配置 --------
# JWT 密鑰 (用於簽署 JWT tokens)
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long

# Session 密鑰 (用於加密 session 數據)
SESSION_SECRET=your_session_secret_key_minimum_32_characters_long

# -------- RSS 聚合設置 --------
# RSS 更新間隔 (毫秒，默認 1 小時)
RSS_UPDATE_INTERVAL=3600000

# RSS 源列表 (用逗號分隔)
RSS_SOURCES=https://feeds.bbci.co.uk/news/rss.xml,https://feeds.cnbc.com/id/100003114/rss/,https://feeds.reuters.com/reuters/topNews

# -------- 前端環境 --------
# 後端 API 地址
VITE_API_URL=http://localhost:3000

# 應用名稱
VITE_APP_NAME=SoWork News

# -------- 服務器配置 --------
# Node 環境
NODE_ENV=development

# 服務器端口
PORT=3000

# -------- 日誌配置 --------
# 日誌級別: debug, info, warn, error
LOG_LEVEL=info

# -------- 其他配置 --------
# 允許的 CORS 來源 (開發環境默認為 *)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
